<Ui>
  <ItemButton name="BaganatorRetailCachedBagItemButtonTemplate" virtual="true" mixin="BaganatorRetailCachedBagItemButtonMixin">
    <Scripts>
      <OnClick method="OnClick"/>
      <OnEnter method="OnEnter"/>
      <OnLeave method="OnLeave"/>
    </Scripts>
    <Layers>
      <Layer level="OVERLAY">
        <FontString parentKey="ItemLevel" inherits="NumberFontNormal"/>
        <FontString parentKey="Expansion" inherits="NumberFontNormal"/>
        <FontString parentKey="BindingText" inherits="NumberFontNormal"/>
        <Texture parentKey="UpgradeArrow"/>
        <Texture parentKey="EquipmentSet"/>
      </Layer>
    </Layers>
  </ItemButton>

  <ItemButton name="BaganatorRetailLiveBagItemButtonTemplate" virtual="true" inherits="ContainerFrameItemButtonTemplate">
    <Scripts>
